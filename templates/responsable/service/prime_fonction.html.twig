{% extends 'responsable/_layout.html.twig' %}

{# Module: Prime de fonction (validation service) #}

{% block title %}Validation des primes de fonction{% endblock %}

{% block rd_body %}
<div class="container">
    <div class="rd-card rd-hero p-4 p-md-5 mb-4 rd-anim">
        <div class="position-relative">
            <div class="d-flex flex-wrap gap-2 justify-content-between align-items-start">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <span class="rd-chip"><i class="fas fa-id-badge"></i> Fonction</span>
                        <span class="rd-chip">Validation service</span>
                        <span class="rd-chip">{{ type|capitalize }}</span>
                    </div>
                    <h1 class="rd-title h3 mb-1">Primes de fonction</h1>
                    <div class="rd-subtle">Valider, retourner, et suivre l'etat des primes.</div>
                </div>
                <div class="d-flex gap-2">
                    <a href="{{ path('responsable_service_dashboard') }}" class="btn btn-outline-secondary rd-btn">
                        <i class="fas fa-arrow-left me-1"></i>Dashboard
                    </a>
                </div>
            </div>

    {% if periodeCourante %}
            <div class="mt-4 rd-kpi p-3 p-md-4">
                <div class="row g-3 align-items-center">
                    <div class="col-md-6">
                        <div class="rd-subtle small">Periode courante</div>
                        <div class="fw-semibold">
                            {{ '%02d'|format(periodeCourante.mois) }}/{{ periodeCourante.annee }}
                            {% if periodeCourante.quinzaine %}(Q{{ periodeCourante.quinzaine }}){% endif %}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                            <span class="rd-chip"><span class="rd-kpi-num">{{ primes|length }}</span> A valider</span>
                            <span class="rd-chip"><span class="rd-kpi-num">{{ validated|length }}</span> Validees</span>
                            <span class="rd-chip"><span class="rd-kpi-num">{{ drafts|length }}</span> Retournees</span>
                        </div>
                    </div>
                </div>
            </div>
    {% endif %}
        </div>
    </div>

        <div class="rd-card p-0 mb-4 rd-anim rd-anim-delay-70">
            <div class="d-flex justify-content-between align-items-center px-3 px-md-4 py-3 rd-card-head">
                <div class="fw-semibold"><i class="fas fa-hourglass-start me-2"></i>En attente de validation</div>
                <span class="rd-chip">{{ primes|length }}</span>
            </div>
            <div class="p-3 p-md-4">
                <div class="table-responsive" data-controller="check-all">
                    <table class="table rd-table table-bordered table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th><input type="checkbox" data-check-all-target="master" data-action="change->check-all#toggleAll"></th>
                                <th>Employe</th>
                                <th>Matricule</th>
                                <th>Taux</th>
                                <th>Jours</th>
                                <th>Note</th>
                                <th>Montant</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for pf in primes %}
                            <tr>
                                <td>
                                    <input type="checkbox" name="selected[]" value="{{ pf.id }}" form="form-batch" data-check-all-target="item" data-action="change->check-all#itemChanged">
                                </td>
                                <td>{{ pf.employee.prenom }} {{ pf.employee.nom }}</td>
                                <td>{{ pf.employee.matricule }}</td>
                                <td>{{ pf.tauxMonetaireFonction }}</td>
                                <td>{{ pf.nombreJours }}</td>
                                <td>{{ pf.noteHierarchique }}</td>
                                <td>{{ pf.getMontantFormate() }}</td>
                                <td class="text-center">
                                    <div class="d-inline-flex gap-1">
                                        <form method="post" action="{{ path('responsable_service_fonction_valider_ligne', { type: type, id: pf.id }) }}" class="d-inline" data-controller="confirm" data-action="submit->confirm#submit" data-confirm-message-value="Valider cette prime ?">
                                            <input type="hidden" name="_token" value="{{ csrf_token('responsable_fonction_valider_ligne') }}">
                                            <button type="submit" class="btn btn-sm btn-success">Valider</button>
                                        </form>
                                        <form method="post" action="{{ path('responsable_service_fonction_retour_ligne', { type: type, id: pf.id }) }}" class="d-inline" data-controller="confirm" data-action="submit->confirm#submit" data-confirm-message-value="Retourner cette prime au gestionnaire ?">
                                            <input type="hidden" name="_token" value="{{ csrf_token('responsable_fonction_retour_ligne') }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Retour</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8" class="text-center text-muted">Aucune prime en attente.</td></tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <form method="post" action="{{ path('responsable_service_fonction_valider_batch', { type: type }) }}" id="form-batch" class="text-end mt-3">
                    <button type="submit" class="btn btn-success rd-btn" name="_token" value="{{ csrf_token('responsable_fonction_valider_batch') }}">Valider la selection</button>
                    <button type="submit" class="btn btn-outline-danger rd-btn ms-2" formaction="{{ path('responsable_service_fonction_retour_batch', { type: type }) }}" formmethod="post" name="_token" value="{{ csrf_token('responsable_fonction_retour_batch') }}">Retourner la selection</button>
                    <a href="{{ path('responsable_service_dashboard') }}" class="btn btn-outline-secondary rd-btn">Retour</a>
                </form>
            </div>
        </div>

    <div class="rd-card p-0 mb-4 rd-anim rd-anim-delay-110">
        <div class="d-flex justify-content-between align-items-center px-3 px-md-4 py-3 rd-card-head">
            <div class="fw-semibold"><i class="fas fa-check-double me-2"></i>Validees (service)</div>
            <span class="rd-chip">{{ validated|length }}</span>
        </div>
        <div class="p-3 p-md-4">
            <div class="table-responsive">
                <table class="table rd-table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employe</th>
                            <th>Matricule</th>
                            <th>Montant</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for pf in validated %}
                        <tr>
                            <td>{{ pf.employee.prenom }} {{ pf.employee.nom }}</td>
                            <td>{{ pf.employee.matricule }}</td>
                            <td>{{ pf.getMontantFormate() }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="text-center py-4 text-muted">Aucune prime validee.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="rd-card p-0 rd-anim rd-anim-delay-150">
        <div class="d-flex justify-content-between align-items-center px-3 px-md-4 py-3 rd-card-head">
            <div class="fw-semibold"><i class="fas fa-undo me-2"></i>Retournees</div>
            <span class="rd-chip">{{ drafts|length }}</span>
        </div>
        <div class="p-3 p-md-4">
            <div class="table-responsive">
                <table class="table rd-table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employe</th>
                            <th>Matricule</th>
                            <th>Montant</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for pf in drafts %}
                        <tr>
                            <td>{{ pf.employee.prenom }} {{ pf.employee.nom }}</td>
                            <td>{{ pf.employee.matricule }}</td>
                            <td>{{ pf.getMontantFormate() }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="text-center py-4 text-muted">Aucune prime retournee.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}

