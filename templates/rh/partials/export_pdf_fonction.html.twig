<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Export PDF - Synthese RH (Prime de fonction)</title>
    <style>
        table { width: 100%; border-collapse: collapse; font-size: 12px; }
        th, td { border: 1px solid #222; padding: 2px 4px; }
        th { background: #e2e2e2; }
    </style>
</head>
<body>
    <h2>Synthese RH - Primes de fonction</h2>
    <table>
        <thead>
        <tr>
            <th>Matricule</th>
            <th>Nom</th>
            <th>Periode</th>
            <th>Division</th>
            <th>Service</th>
            <th>Statut</th>
            <th>Taux</th>
            <th>Jours</th>
            <th>Note</th>
            <th>Montant</th>
        </tr>
        </thead>
        <tbody>
        {% for pf in primes %}
            <tr>
                <td>{{ pf.employee.matricule }}</td>
                <td>{{ pf.employee.getFullName() }}</td>
                <td>{{ pf.periodePaie }}</td>
                <td>{{ pf.employee.employeeSituations[0].service.division.nom ?? '' }}</td>
                <td>{{ pf.employee.employeeSituations[0].service.nom ?? '' }}</td>
                <td>{{ pf.status|capitalize }}</td>
                <td>{{ pf.tauxMonetaireFonction }}</td>
                <td>{{ pf.nombreJours }}</td>
                <td>{{ pf.noteHierarchique }}</td>
                <td>{{ pf.getMontantFormate() }}</td>
            </tr>
        {% else %}
            <tr><td colspan="10">Aucune donnee.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</body>
</html>
