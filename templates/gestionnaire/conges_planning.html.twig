{% extends 'base.html.twig' %}

{% block title %}Planning des congés{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">
            <i class="fas fa-calendar-alt text-primary me-2"></i>Planning des congés
        </h1>
        <a href="{{ path('gestionnaire_dashboard') }}" class="btn btn-outline-secondary">
            TABLEAU DE BORD
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="fas fa-calendar-week fs-1 mb-3"></i>
            <p class="fs-5">Le planning des congés de vos collaborateurs sera affiché ici.</p>
            <p>Cette fonctionnalité est en cours de développement.</p>
        </div>
    </div>
</div>
{% endblock %}
