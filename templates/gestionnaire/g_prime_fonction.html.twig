{% extends 'base.html.twig' %}

{# Module: Gestionnaire - saisie prime de fonction #}

{% block title %}
    Saisie - prime de fonction ({{ type == 'mensuelle' ? 'Paie mensuelle' : 'Paie quinzaine' }})
{% endblock %}

{% block body %}
<div class="container py-5">

    {% for lbl, msgs in app.flashes %}
        {% for m in msgs %}
            <div class="alert alert-{{ lbl == 'error' ? 'danger' : (lbl == 'warning' ? 'warning' : 'success') }} alert-dismissible fade show">
                {{ m }}
                <button class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">Saisie - prime de fonction</h2>
            <div class="text-muted">
                Type: <strong>{{ type == 'mensuelle' ? 'Mensuelle' : 'Quinzaine' }}</strong> |
                Periode: <strong>{{ '%02d'|format(periode.mois) }}/{{ periode.annee }}{% if periode.quinzaine %} (Q{{ periode.quinzaine }}){% endif %}</strong>
            </div>
        </div>
        <a href="{{ path('gestionnaire_dashboard') }}" class="btn btn-outline-secondary">TABLEAU DE BORD</a>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">En cours de saisie</span>
            <span class="badge bg-light text-dark">{{ pending|length }}</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Matricule</th>
                            <th>Employe</th>
                            <th>Taux monetaire</th>
                            <th>Nombre de jours</th>
                            <th>Note (0..1)</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for es in pending %}
                        <form method="post" action="{{ path('gestionnaire_submit_fonction_line', { type: type, esId: es.id }) }}">
                            <input type="hidden" name="periode" value="{{ periode.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('gestionnaire_submit_fonction_line_' ~ es.id) }}">
                            <tr>
                                <td><span class="badge bg-secondary">{{ es.employee.matricule }}</span></td>
                                <td><strong>{{ es.employee.prenom }} {{ es.employee.nom }}</strong></td>
                                <td>
                                    <span class="badge bg-info">{{ es.employee.categorieFonction ? es.employee.categorieFonction.tauxMonetaire : 0 }} Dhs</span>
                                </td>
                                <td><input name="vals[nombreJours]" type="number" step="0.5" min="0" class="form-control" required></td>
                                <td><input name="vals[noteHierarchique]" type="number" step="0.01" min="0" max="1" class="form-control" required></td>
                                <td>
                                    <button type="submit" class="btn btn-sm btn-success">
                                        Soumettre
                                    </button>
                                </td>
                            </tr>
                        </form>
                    {% else %}
                        <tr><td colspan="6" class="text-center py-4 text-muted">Aucune ligne a saisir.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Deja soumises</span>
            <span class="badge bg-light text-dark">{{ submittedMap|length }}</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Matricule</th>
                            <th>Employe</th>
                            <th>Montant</th>
                            <th>Taux</th>
                            <th>Jours</th>
                            <th>Note</th>
                            <th>Statut</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for empId, pf in submittedMap %}
                        <tr>
                            <td><span class="badge bg-secondary">{{ pf.employee.matricule }}</span></td>
                            <td><strong>{{ pf.employee.prenom }} {{ pf.employee.nom }}</strong></td>
                            <td><span class="fw-semibold">{{ pf.getMontantFormate() }}</span></td>
                            <td>{{ pf.tauxMonetaireFonction }}</td>
                            <td>{{ pf.nombreJours }}</td>
                            <td>{{ pf.noteHierarchique }}</td>
                            <td>
                                {% set statusClass = pf.status == 'submitted' ? 'warning' : (pf.status == 'service_validated' ? 'info' : 'success') %}
                                <span class="badge bg-{{ statusClass }}">{{ pf.status|capitalize }}</span>
                            </td>
                            <td>
                                <form method="post" action="{{ path('gestionnaire_revert_fonction_line', { type: type, pfId: pf.id }) }}" class="d-inline" data-controller="confirm" data-action="submit->confirm#submit" data-confirm-message-value="Remettre cette ligne en modification ?">
                                    <input type="hidden" name="periode" value="{{ periode.id }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('gestionnaire_revert_fonction_line_' ~ pf.id) }}">
                                    <button type="submit" class="btn btn-sm btn-warning"
                                        {% if pf.status != 'submitted' %}disabled{% endif %}>
                                        Modifier
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="8" class="text-center py-4 text-muted">Aucune ligne soumise.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
